{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "aspen",
  "name": "MoEngage",
  "colors": {
    "primary": "#001447",
    "light": "#4D6DCE",
    "dark": "#001447"
  },
  "appearance": {
    "default": "light"
  },
  "background": {
    "decoration": "gradient",
    "color": {
      "light": "#f4eee2"
    }
  },
  "fonts": {
    "heading": {
      "family": "circular",
      "source": "https://www.moengage.com/wp-content/themes/moengagewp/assets/fonts/CircularXXWeb-Regular.woff2",
      "format": "woff2"
    },
    "body": {
      "family": "circular",
      "source": "https://www.moengage.com/wp-content/themes/moengagewp/assets/fonts/CircularXXWeb-Regular.woff2",
      "format": "woff2"
    }
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Support",
          "icon": "headset",
          "href": "https://help.moengage.com/hc/en-us"
        },
        {
          "anchor": "Blog",
          "icon": "newspaper",
          "href": "https://www.moengage.com/blog"
        }
      ]
    },
    "languages": [
      {
        "language": "en",
        "tabs": [
          {
            "tab": "Developer Guide",
            "groups": [
              {
                "group": "Ecommerce Platforms",
                "pages": [
                  {
                    "group": "Shopify",
                    "pages": [
                      "shopify-2-0",
                      "events-and-user-data-tracking",
                      "user-data-sync",
                      "sync-product-catalog",
                      "validation-integration",
                      "user-profile-management",
                      "untitled-page"
                    ]
                  }
                ]
              },
              {
                "group": "Woo Commerce",
                "pages": [
                  "woo-commerce"
                ]
              }
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://www.moengage.com"
  },
  "navbar": {
    "links": [
      {
        "label": "Login",
        "href": "https://dashboard.moengage.com/v4"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Request Demo",
      "href": "https://www.moengage.com/request-demo"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "linkedin": "https://www.linkedin.com/company/moengage",
      "x": "https://x.com/i/flow/login?redirect_after_login=%2Fmoengage",
      "youtube": "https://www.youtube.com/c/MoEngage_Global",
      "facebook": "https://www.facebook.com/moengage"
    }
  },
  "seo": {
    "metatags": {
      "robots": "noindex"
    }
  }
}